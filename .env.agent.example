# Agent box environment — for `docker compose -f docker-compose.agent.yml up -d`.
# All three OO_* values are required. Get them from your master by running:
#
#   docker compose exec worker bun scripts/create-region.ts --slug us-east --label "US East (Virginia)"
#
# The script prints all three in the right format.

OO_MASTER_URL=https://master.example.com
OO_AGENT_KEY=oo_REPLACE_WITH_PRINTED_KEY
OO_REGION_SLUG=us-east

# Optional — defaults shown
# OO_AGENT_POLL_WAIT_SEC=30
# OO_WORKERS_TAG=latest
# LOG_LEVEL=info

# ⚠ SECURITY — read before enabling.
# OO_AGENT_TLS_INSECURE=1 disables TLS certificate verification for the
# agent→master connection ONLY (probe targets stay validated). For a
# self-signed / internal-CA master. This is NOT low risk: anyone on the
# agent↔master network path can then read or tamper with this traffic —
# suppress FAILED results, inject false SUCCESS, or steal OO_AGENT_KEY on
# the first poll. Prefer a real cert (Let's Encrypt) or a Tailscale /
# Wireguard tunnel. Only uncomment if you accept that trade-off:
# OO_AGENT_TLS_INSECURE=1
