{
  "name": "oo-workers",
  "version": "0.4.2",
  "description": "Self-hosted distributed monitoring workers — HTTP, API, and Playwright browser checks. The OSS engine behind ObserveOne.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "migrate": "bun src/db/migrate.ts",
    "build:ui": "mkdir -p public && cp src/ui/index.html src/ui/docs.html public/ && bun build src/ui/app.ts --outdir public --target browser",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@playwright/test": "1.57.0",
    "axios": "^1.16.0",
    "bullmq": "^5.76.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "jsonpath": "^1.3.0",
    "playwright": "1.57.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsonpath": "^0.2.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
