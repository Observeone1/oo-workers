{
  "name": "oo-workers",
  "version": "1.10.0",
  "description": "Self-hosted distributed monitoring workers — HTTP, API, and Playwright browser checks. The OSS engine behind ObserveOne.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "migrate": "bun src/db/migrate.ts",
    "build:ui": "mkdir -p public && cp src/ui/index.html src/ui/docs.html src/ui/tokens.css src/ui/dashboard.css src/ui/docs.css public/ && bun build src/ui/app.ts --outdir public --target browser",
    "test": "bun test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src scripts",
    "lint:fix": "eslint src scripts --fix",
    "knip": "knip",
    "test:integration": "sh scripts/run-integration.sh",
    "test:backup": "bun scripts/backup-restore-test.ts",
    "test:import": "bun scripts/import-from-saas-test.ts",
    "test:tcp": "bun scripts/tcp-banner-test.ts",
    "test:tls": "bun scripts/tls-cert-test.ts",
    "test:qa-alerting": "bun scripts/qa-alerting-test.ts",
    "test:ui:e2e": "playwright test --config=playwright.ui.config.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": "prettier --write",
    "*.ts": "eslint --fix"
  },
  "dependencies": {
    "@playwright/test": "1.57.0",
    "bullmq": "^5.76.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "ioredis": "^5.10.1",
    "jsonpath": "^1.3.0",
    "nodemailer": "^8.0.7",
    "playwright": "1.57.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsonpath": "^0.2.4",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^6.13.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
