# oo-workers — environment variables.
#
# For fresh installs, prefer `./scripts/setup.sh` — it writes .env with
# strong random Postgres + Redis passwords. The values below are
# defaults the docker-compose stack falls back to when .env is missing.

# --- Postgres ---
POSTGRES_USER=oo
POSTGRES_PASSWORD=oo
POSTGRES_DB=oo_workers
POSTGRES_PORT=5432

# --- Redis ---
# REDIS_PASSWORD empty by default for backwards-compat with existing
# stacks. Run scripts/setup.sh to get a strong random value.
REDIS_PASSWORD=
REDIS_PORT=6379

# --- UI / HTTP server ---
UI_PORT=3001
# OO_BIND_ADDR=0.0.0.0   # uncomment to expose UI beyond localhost (pair with TLS)

# --- Worker tuning ---
LOG_LEVEL=info
API_CHECK_CONCURRENCY=10
URL_MONITOR_CONCURRENCY=20
QA_PROJECT_CONCURRENCY=5

# --- Object storage (RustFS by default; override to point at any S3 API) ---
# Defaults below match docker-compose.yml's bundled rustfs service. To use
# AWS S3 / Cloudflare R2 / Backblaze B2 / on-prem MinIO/Ceph instead, override
# OO_OBJECT_STORAGE_ENDPOINT and credentials.
OO_OBJECT_STORAGE_ENDPOINT=http://rustfs:9000
OO_OBJECT_STORAGE_REGION=us-east-1
OO_OBJECT_STORAGE_BUCKET=oo-workers
OO_OBJECT_STORAGE_ACCESS_KEY=oo-workers-access
OO_OBJECT_STORAGE_SECRET_KEY=oo-workers-secret-change-me

# --- TLS overlay (docker-compose.tls.yml) ---
# OO_DOMAIN=monitor.example.com

# --- For running outside docker-compose ---
# DATABASE_URL=postgres://oo:oo@localhost:5432/oo_workers
# REDIS_URL=redis://localhost:6379
