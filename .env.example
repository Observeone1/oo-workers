# oo-workers - environment variables.
#
# For fresh installs, prefer `./scripts/setup.sh` - it writes .env with
# strong random Postgres + Redis passwords. The values below are
# defaults the docker-compose stack falls back to when .env is missing.

# --- Postgres ---
POSTGRES_USER=oo
POSTGRES_PASSWORD=oo
POSTGRES_DB=oo_workers
POSTGRES_PORT=5432

# --- Redis ---
# REDIS_PASSWORD empty by default for backwards-compat with existing
# stacks. Run scripts/setup.sh to get a strong random value.
REDIS_PASSWORD=
REDIS_PORT=6479
# The worker (when run outside docker compose, i.e. `bun src/index.ts` on the
# host) reads this directly. Inside docker compose, the worker container
# uses the compose-network hostname `redis:6379` regardless.
REDIS_URL=redis://localhost:6479

# --- UI / HTTP server ---
UI_PORT=3001
# OO_BIND_ADDR=0.0.0.0   # uncomment to expose UI beyond localhost (pair with TLS)

# --- Worker tuning ---
LOG_LEVEL=info
# Master-side concurrency knobs for each monitor type. Higher = more parallel
# probes per second. Tune up if the host has the cores; tune down if you're
# rate-limited by your monitoring targets.
API_CHECK_CONCURRENCY=10
URL_MONITOR_CONCURRENCY=20
QA_PROJECT_CONCURRENCY=5
# TCP / UDP / DB / TLS share a default of 10; override if a sweep is needed.
# TCP_MONITOR_CONCURRENCY=10
# UDP_MONITOR_CONCURRENCY=10
# DB_MONITOR_CONCURRENCY=10
# TLS_MONITOR_CONCURRENCY=10
# Scheduler tick interval (ms). Default 5000 = check what's due every 5s.
# Lower = tighter freshness, higher tick load. Don't go below 1000.
# SCHEDULER_TICK_MS=5000

# --- Multi-region agent mode ---
# A regional agent is a second oo-workers process that runs probes from a
# different physical location and ships results back to master via HTTP.
# Set OO_WORKER_ROLE=agent on the agent container; it then needs the master
# URL + a region-bound API key (created via the master's Regions page,
# scope=agent).
# OO_WORKER_ROLE=agent
# OO_MASTER_URL=https://monitor.example.com
# OO_AGENT_KEY=oo_<43chars>
# OO_REGION_SLUG=us-east
# Long-poll wait in seconds. Master clamps to [1, 60]. 30 is a good balance
# between responsiveness and master connection count.
# OO_AGENT_POLL_WAIT_SEC=30
# Self-signed master cert? Set OO_AGENT_TLS_INSECURE=1 on the AGENT only
# (scoped to the agent->master link; probe targets stay validated). This is
# NOT low risk: an attacker on the agent<->master path can suppress FAILED
# results, inject false SUCCESS, or steal the agent key. Use a real cert
# (Let's Encrypt) or a Tailscale/Wireguard tunnel wherever possible.
# OO_AGENT_TLS_INSECURE=1

# --- Object storage (RustFS by default; override to point at any S3 API) ---
# Defaults below match docker-compose.yml's bundled rustfs service. To use
# AWS S3 / Cloudflare R2 / Backblaze B2 / on-prem MinIO/Ceph instead, override
# OO_OBJECT_STORAGE_ENDPOINT and credentials.
OO_OBJECT_STORAGE_ENDPOINT=http://rustfs:9000
OO_OBJECT_STORAGE_REGION=us-east-1
OO_OBJECT_STORAGE_BUCKET=oo-workers
OO_OBJECT_STORAGE_ACCESS_KEY=oo-workers-access
OO_OBJECT_STORAGE_SECRET_KEY=oo-workers-secret-change-me
# Force path-style (vhost-style is the S3 default; some on-prem backends
# only accept path-style). Defaults to false for AWS/R2; true for RustFS.
# OO_OBJECT_STORAGE_FORCE_PATH_STYLE=true

# --- Email alert channel (SMTP) ---
# Required only if you create an `email` alert channel. The SMTP server is
# operator-level config; each email channel just stores its recipient.
# Leave OO_SMTP_HOST unset to keep email channels disabled.
# OO_SMTP_HOST=smtp.example.com
# OO_SMTP_PORT=587            # 465 => implicit TLS auto-enabled
# OO_SMTP_SECURE=false        # true for implicit TLS (port 465)
# OO_SMTP_USER=apikey
# OO_SMTP_PASS=change-me
# OO_SMTP_FROM=oo-workers@example.com   # falls back to OO_SMTP_USER
#
# Dev: start-oo-workers.sh runs a Mailpit container - point SMTP at it
# (OO_SMTP_HOST=localhost OO_SMTP_PORT=1025) and read delivered mail at
# http://localhost:8025. With OO_MAILPIT_API set, the dashboard's channel
# "Send test" confirms the email actually landed (dev convenience only).
# OO_MAILPIT_API=http://localhost:8025

# --- TLS overlay (docker-compose.tls.yml) ---
# OO_DOMAIN=monitor.example.com

# --- For running outside docker-compose ---
# DATABASE_URL=postgres://oo:oo@localhost:5432/oo_workers
# REDIS_URL=redis://localhost:6379
