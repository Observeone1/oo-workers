# oo-workers — environment variables.
# Copy to .env and adjust for your setup. All values shown are defaults.

# --- Postgres (used by docker-compose to seed the postgres container
#     AND by the worker via DATABASE_URL) ---
POSTGRES_USER=oo
POSTGRES_PASSWORD=oo
POSTGRES_DB=oo_workers
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Worker tuning ---
LOG_LEVEL=info
API_CHECK_CONCURRENCY=10
URL_MONITOR_CONCURRENCY=20
QA_PROJECT_CONCURRENCY=5

# --- For running outside docker-compose (override the in-compose defaults) ---
# DATABASE_URL=postgres://oo:oo@localhost:5432/oo_workers
# REDIS_URL=redis://localhost:6379
